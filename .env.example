# --- WBS API (nguồn dữ liệu) ---
WBS_BASE_URL=http://ip:port
WBS_API_KEY=your_wbs_api_key
WBS_PAGE_SIZE=500
WBS_DEPARTMENTS_PATH=/api/departments       # API 1: list parts
WBS_WORKS_PATH=/api/works/search            # default target (centralized)
WBS_WORK_PROFILES_PATH=/api/work-profiles   # API 2: per-part work codes

# --- LangFlow API (đích) ---
LANGFLOW_BASE_URL=http://langflow-ip:port
LANGFLOW_API_KEY=your_langflow_api_key
LANGFLOW_FILE_NAME=wbs_agent_knowledge      # base name: default file = this; part file = this_<slug>

# --- Service ---
SYNC_INTERVAL_HOURS=6
SYNC_RUN_ON_START=true
SYNC_DEFAULT_ENABLED=true                   # cũng push file tập trung (default)
SYNC_MAX_RETRIES=3
SYNC_RETRY_BACKOFF=5
STATE_DIR=./data
LOG_LEVEL=INFO
HTTP_TIMEOUT=30
